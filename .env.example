# --- 서버 및 네트워크 설정 ---
PORT=3000
HOST="xxx.xxx.xx.xxx"                     # 배포 서버 IP
BASE_URL="http://your-ip-or-domain:3000"  # 서버의 전체 주소 (구글 OAuth 리디렉션 등에 사용)

# --- 데이터베이스 및 인증 ---
DATABASE_URL="postgresql://..."           # Supabase 또는 DB 접속 주소
JWT_SECRET="your_jwt_secret_key"          # Access Token 암호화 키
REFRESH_SECRET="your_refresh_secret_key"  # Refresh Token 암호화 키
CRYPTO_SECRET_KEY="your_crypto_key"       # 데이터 추가 암호화용 키

# --- 구글 OAuth 설정 ---
GOOGLE_OAUTH_CLIENT="your_client_id"      # 구글 콘솔에서 발급받은 클라이언트 ID
GOOGLE_OAUTH_SECRET="your_client_secret"  # 구글 콘솔에서 발급받은 비밀번호

# --- 이메일 전송 (Nodemailer 등) ---
GMAIL_USER="your-email@gmail.com"         # 발신용 지메일 주소
GMAIL_PASSWORD="your-app-password"        # 지메일 앱 비밀번호 (2단계 인증 필요)

# --- 인프라 및 보안 ---
CA_CERTIFICATE="your_ca_cert"             # DB 보안 연결용 인증서 (필요 시)